# Database
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=replace-with-database-password
DATABASE_HOSTNAME=replace-with-database-host
DATABASE_PORTNAME=5432
DATABASE_NAME=fumisync

# JWT / auth
SECRET_KEY=replace-with-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
INVITE_TTL_HOURS=72

# App secret encryption
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-fernet-key
HASH_KEY=replace-with-separate-hmac-key

# Infrastructure
REDIS_URL=redis://localhost:6379/0
BACKEND_BASE_URL=http://localhost:8000

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com

# ToroForge / Toronet
TOROFORGE_NETWORK=testnet
TOROFORGE_BASE_URL=https://replace-with-toroforge-base-url
TOROFORGE_CONNECTW_URL=https://replace-with-connectw-url
TOROFORGE_DEPLOYER_URL=https://replace-with-deployer-url
TOROFORGE_ADMIN=replace-with-toroforge-admin
TOROFORGE_ADMINPWD=replace-with-toroforge-admin-password
